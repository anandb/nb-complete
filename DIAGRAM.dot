    }  /* end cluster_ui */

    /* ================================================================ */
    /* Relationships — Contract Implementations                         */
    /* ================================================================ */

    SessionControl -> SessionQuery [arrowhead=empty label="extends"]

    SlashCommandInterceptor -> SlashCommandCallback [style=solid label="uses"]
    SlashCommandInterceptor -> SlashCommandHandler [style=solid label="uses"]

    /* ================================================================ */
    /* Relationships — Manager Compositions                             */
    /* ================================================================ */

    SessionManager -> SessionStateMachine [arrowhead=diamond label="manages state"]
    SessionManager -> SessionCacheManager [arrowhead=diamond label="delegates caching"]
    SessionManager -> SessionRpcClient [arrowhead=diamond label="delegates RPC"]
    ProcessManager -> ServerProcessLifecycle [arrowhead=diamond label="delegates start/stop"]
    ProcessManager -> AcpReconnectManager [arrowhead=diamond label="handles reconnect"]
    ProcessManager -> AcpRequestRouter [arrowhead=diamond label="routes requests"]
    ProcessManager -> AcpProtocolClient [arrowhead=diamond label="owns RPC transport"]
    ProcessManager -> McpToolAdapter [arrowhead=diamond label="delegates tool execution"]
    ProcessManager -> SlashCommandInterceptor [arrowhead=diamond label="intercepts commands"]

    ServerProcessLifecycle -> AcpProtocolClient [style=solid label="initializes"]
    AcpReconnectManager -> AcpProtocolClient [style=solid label="reconnects"]
    AcpRequestRouter -> PermissionHandler [style=solid label="delegates permissions"]

    SessionRpcClient -> ProcessManager [style=solid label="calls sendRequest"]

    StrategyRegistry -> SubAgentTitleResolver [style=solid label="resolves titles"]
    StrategyRegistry -> ToolDataExtractor [style=solid label="extracts tool data"]

    /* ================================================================ */
    /* Relationships — MCP Compositions                                 */
    /* ================================================================ */

    McpManager -> McpServer [arrowhead=diamond label="manages server"]
    McpManager -> McpTools [arrowhead=diamond label="manages tools"]
    McpToolAdapter -> McpManager [arrowhead=diamond label="adapts"]

    /* ================================================================ */
    /* Relationships — UI Compositions                                  */
    /* ================================================================ */

    AssistantTopComponent -> ChatThreadPanel [arrowhead=diamond label="creates & owns"]
    AssistantTopComponent -> ConfigPanelController [arrowhead=diamond label="creates & owns"]
    AssistantTopComponent -> SessionLifecycleHandler [arrowhead=diamond label="creates & owns"]
    AssistantTopComponent -> ComponentLifecycleHandler [arrowhead=diamond label="creates & owns"]
    AssistantTopComponent -> MessageSender [arrowhead=diamond label="creates & owns"]
    AssistantTopComponent -> InputHandler [arrowhead=diamond label="creates & owns"]
    AssistantTopComponent -> StatusController [arrowhead=diamond label="creates & owns"]
    AssistantTopComponent -> AttachmentUiHandler [arrowhead=diamond label="uses"]

    ChatThreadPanel -> StreamingCoordinator [arrowhead=diamond label="delegates streaming"]
    ChatThreadPanel -> BubbleFactory [style=solid label="creates bubbles via"]
    ChatThreadPanel -> MessageFilterManager [style=solid label="queries visibility"]
    ChatThreadPanel -> ScrollController [style=solid label="auto-scroll control"]

    MessageBubble -> BubbleStreamer [arrowhead=diamond label="delegates streaming append"]
    MessageBubble -> BubbleContentRenderer [arrowhead=diamond label="delegates render update"]
    MessageBubble -> BubbleAccordionManager [arrowhead=diamond label="delegates expand/collapse"]
    MessageBubble -> BubbleThemeApplier [arrowhead=diamond label="delegates theme colors"]

    BubbleContentRenderer -> CollapsibleActivityPane [style=solid label="creates"]
    BubbleContentRenderer -> CollapsibleCodePane [style=solid label="creates"]
    BubbleContentRenderer -> CollapsibleToolPane [style=solid label="creates"]
    BubbleContentRenderer -> FitEditorPane [style=solid label="creates"]
    BubbleContentRenderer -> HtmlContentPreparer [style=solid label="converts markdown"]

    BubbleAccordionManager -> AccordionGroup [style=solid label="registers with"]

    BubbleThemeApplier -> MessageBubble [style=solid label="updates owner background"]

    BaseCollapsiblePane -> CollapsibleActivityPane [arrowhead=empty label="extends"]
    BaseCollapsiblePane -> CollapsibleCodePane [arrowhead=empty label="extends"]
    BaseCollapsiblePane -> CollapsibleToolPane [arrowhead=empty label="extends"]

    AccordionGroup -> BaseCollapsiblePane [arrowhead=diamond label="manages panes"]

    MarkdownStyledRenderer -> MarkdownTokenizer [style=solid label="tokenizes inline markup"]
    MarkdownStyledRenderer -> StyleResolver [style=solid label="resolves token→attributes"]

    ChatLayoutBuilder -> AssistantTopComponent [style=solid label="builds layout for"]
    ChatLayoutBuilder -> UIUtils [style=solid label="uses utilities"]

    SessionLifecycleHandler -> ChatThreadPanel [style=solid label="updates chat"]
    SessionLifecycleHandler -> ConfigPanelController [style=solid label="updates config"]

    MessageSender -> SlashCommandInterceptor [style=solid label="intercepts commands"]

    PermissionDialogManager -> PermissionHandler [style=solid label="routes requests"]
    PermissionDialogManager -> PermissionBubble [arrowhead=diamond label="displays bubble"]

    ConfigPanelController -> ModelVariantResolver [arrowhead=diamond label="resolves models"]
    AttachmentManager -> AttachmentUiHandler [arrowhead=diamond label="manages state"]

    /* ================================================================ */
    /* Relationships — Theme & Rendering                                */
    /* ================================================================ */

    ThemeManager -> ColorTheme [style=solid label="provides"]
    ThemeManager -> IconResourceManager [style=solid label="delegates icons/fonts"]

    BaseCollapsiblePane -> ThemeManager [style=solid label="reads icons & fonts"]
    CollapsibleCodePane -> ThemeManager [style=solid label="reads fonts"]
    BubbleStreamer -> ColorTheme [style=solid label="reads"]
    BubbleContentRenderer -> ColorTheme [style=solid label="reads"]
    BubbleThemeApplier -> ColorTheme [style=solid label="reads"]
    MarkdownStyledRenderer -> ColorTheme [style=solid label="reads"]

    /* ================================================================ */
    /* Relationships — Constants Usage                                  */
    /* ================================================================ */

    MessageBubble -> TimingConstants [style=solid label="stream flush timing"]
    StreamingCoordinator -> TimingConstants [style=solid label="stream flush timing"]

    PreferenceKeys -> PluginSettings [style=solid label="preference constants"]
}
