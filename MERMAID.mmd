classDiagram
    direction LR

    %% ------------------------------------------------------------------------
    %% Contract Layer — Interfaces & Ports
    %% ------------------------------------------------------------------------

    class SessionQuery {
        <<interface>>
        +getCurrentSessionId() : String
        +getCurrentSessionDirectory() : String
        +getCurrentState() : SessionState
        +loadSessionFromServer(String, String) : CompletableFuture~List~SessionConfigOption~~
        +getCustomTitle(String, String) : String
        +isDescendantOfCurrent(String) : boolean
        +isHidden(String) : boolean
    }

    class SessionControl {
        <<interface>>
        +addSessionListener(SessionListener)
        +removeSessionListener(SessionListener)
        +createSession(String) : CompletableFuture~Session~
        +loadSession(String) : boolean
        +deleteSession(String) : CompletableFuture~Void~
        +setSessionConfigOption(String, String, String) : CompletableFuture~Void~
        +renameSession(String, String)
        +createNewSession(String)
        +closeSession()
        +refreshSessions()
        +refreshSessionList()
        +stopCurrentMessage()
        +onTurnEnded()
        +canSendMessage() : boolean
        +canStopMessage() : boolean
        +forceCancelCurrentMessage()
        +setHidden(String, boolean)
    }

    class ProcessControl {
        <<interface>>
        +ensureStarted()
        +restartServer()
        +sendMessage(String, String, Map, List) : CompletableFuture~JsonNode~
        +stopMessage(String) : CompletableFuture~Void~
        +whenReady() : CompletableFuture~Void~
        +touchConnection()
        +getToolExecutor() : ToolExecutor
        +getSlashCommandInterceptor() : SlashCommandInterceptor
        +setPermissionHandler(PermissionHandler)
        +setStatusListener(Consumer~String~)
        +setCrashHandler(Runnable)
        +getAvailableCommands() : List~AvailableCommand~
        +shutdown()
    }

    class ToolExecutor {
        <<interface>>
        +start()
        +stop()
        +waitForReady() : CompletableFuture~Void~
        +disable()
        +isDisabled() : boolean
        +checkServerSupport(JsonNode)
        +getServerConfig() : List~Map~
    }

    class SessionListener {
        <<interface>>
        +onSessionListUpdated(List~Session~)
        +onSessionStarted(String)
        +onSessionLoaded(String, List~SessionConfigOption~, boolean)
        +onSessionLoading(boolean)
        +onSessionError(String)
        +onSessionUpdate(SessionUpdate)
    }

    class UpdateDispatcher {
        <<interface>>
        +handle(SessionUpdate, UIHandler)
    }

    class UIHandler {
        <<interface>>
        +displayMessage(ProcessedMessage)
        +updateConfig(List~SessionConfigOption~)
        +refreshSessions()
        +updateUsage(long, long)
    }

    class PermissionHandler {
        <<interface>>
        +handlePermissionRequest(String, JsonNode, CompletableFuture~String~)
    }

    class SlashCommandHandler {
        <<interface>>
        +handle(String, Lookup) : CompletableFuture~Boolean~
    }

    class SlashCommandProvider {
        <<interface>>
        +getCommand() : String
        +getDescription() : String
        +getHandler() : SlashCommandHandler
    }

    class SlashCommandCallback {
        <<interface>>
        +expandOptionsPanel()
        +popupModelCombo()
        +popupAgentCombo()
        +popupThinkingCombo()
        +popupSessionCombo()
        +popupNewSession()
        +displayToolMessage(String, String)
    }

    class SlashCommandInterceptor {
        -Map~String,CommandInfo~ commands
        -SlashCommandCallback callback
        +intercept(String, Lookup) : boolean
        +setCallback(SlashCommandCallback)
        +registerCommand(String, CommandInfo)
        +getCommands() : Map
    }

    %% ------------------------------------------------------------------------
    %% Model Layer — Data Classes & Records
    %% ------------------------------------------------------------------------

    class Session {
        <<record>>
        +String id
        +String title
        +String cwd
        +String directory
        +String parentID
        +String updatedAt
        +List~Object~ mcpServers
        +List~SessionConfigOption~ configOptions
        +effectiveDirectory() : String
        +projectName() : String
    }

    class SessionState {
        <<enum>>
        IDLE
        LOADING
        STREAMING
        STOPPING
        +canTransitionTo(SessionState) : boolean
        +canSendMessage() : boolean
        +canStopMessage() : boolean
        +isActive() : boolean
    }

    class MessageType {
        <<enum>>
        agent_message_chunk
        agent_thought_chunk
        available_commands_update
        plan
        tool_call
        tool_call_update
        usage_update
        user_message_chunk
        config_options_update
        session_info_update
        message
        error_response
        responding_finished
        end_turn
        +isThought() : boolean
        +isTool() : boolean
        +isAssistant() : boolean
        +roleName() : String
    }

    class SessionUpdate {
        <<record>>
        +String jsonrpc
        +String method
        +Params params
        +type() : MessageType
        +message() : String
        +isThinking() : boolean
        +content() : Content
        +messageId() : String
        +status() : String
        +kind() : String
        +toolCallId() : String
    }

    class ProcessedMessage {
        <<record>>
        +MessageType messageType
        +String text
        +String messageId
        +String kind
        +String toolTitle
        +boolean streaming
        +String status
        +isIgnorable() : boolean
        +createError(...) : ProcessedMessage$
    }

    class Message {
        <<record>>
        +String id
        +String type
        +Prompt prompt
        +Completion completion
        +String state
    }

    class SessionConfigOption {
        <<record>>
        +String id
        +String name
        +String description
        +String category
        +String type
        +String currentValue
        +List~SessionConfigSelectOption~ options
    }

    class AttachedFile {
        <<record>>
        +String filename
        +String mimeType
        +String base64Data
        +long size
    }

    class ToolCallData {
        +String toolCallId
        +String title
        +String command
        +String kind
        +String status
        +String text
        +shouldDisplay(String) : boolean
        +isDone() : boolean
    }

    class ModelRecords {
        <<constants>>
    }

    class MessageTransformer {
        +convert(Message) : ProcessedMessage
    }

    %% ------------------------------------------------------------------------
    %% Support Layer — Utilities & Constants
    %% ------------------------------------------------------------------------

    class PreferenceKeys {
        <<constants>>
        +MODULE_ANCHOR$
        +ACP_EXECUTABLE_PATH$
        +PROCESS_ARGUMENTS$
        +COMBINE_TOOL_THOUGHT$
        +TOOLBAR_*$
    }

    class PluginSettings {
        <<singleton>>
        +getPreamble() : String$
        +setPreamble(String)$
        +getCustomUserIcon() : String$
        +getSessionIdleTimeout() : long$
    }

    class JsonFields {
        <<constants>>
        +SESSION_ID$
        +MESSAGE_ID$
        +TYPE$
        +CONTENT$
        +TEXT$
        +TOOL_TITLE$
        +ROLE$
        +MODEL$
    }

    class ToolDataExtractor {
        <<utility>>
        +extractToolCallId(JsonNode) : String$
        +classify(JsonNode) : MessageClassification$
        +stripMetadata(String) : String$
        +extractToolTitle(JsonNode) : String$
    }

    class ToolContextExtractor {
        <<utility>>
        +extractToolContext(JsonNode) : String$
        +truncatePath(String) : String$
        +truncateCommand(String) : String$
    }

    class TimingConstants {
        <<constants>>
        +STREAM_FLUSH_MS$ int
        +HELP_FLASH_INTERVAL_MS$ int
    }

    class BrowserUtils {
        <<utility>>
        +openOrCopyUrl(String, Component, Consumer)$
    }

    class LanguageResolver {
        <<utility>>
        +fromPath(String) : String$
    }

    class TextScanner {
        <<utility>>
        +containsAsciiArt(String) : boolean$
    }

    %% ------------------------------------------------------------------------
    %% Manager Layer — Business Logic
    %% ------------------------------------------------------------------------

    class SessionManager {
        <<SessionControl, SessionQuery>>
        -ObjectMapper objectMapper
        -CopyOnWriteArrayList~SessionListener~ listeners
        -SessionStateMachine stateMachine
        -String currentSessionId
        -SessionCacheManager cacheManager
        -SessionRpcClient rpcClient
        +getInstance() : SessionManager$
        +createSession(String) : CompletableFuture~Session~
        +loadSession(String) : boolean
        +deleteSession(String) : CompletableFuture~Void~
        +renameSession(String, String)
        +refreshSessions()
        +createNewSession(String)
        +stopCurrentMessage()
        +onTurnEnded()
        +closeSession()
        +setHidden(String, boolean)
    }

    class ProcessManager {
        <<ProcessControl>>
        -AtomicReference~AcpProtocolClient~ rpcClient
        -ServerProcessLifecycle serverLifecycle
        -AcpReconnectManager reconnectMgr
        -AcpRequestRouter requestRouter
        -McpToolAdapter toolExecutor
        -SlashCommandInterceptor slashCmdInterceptor
        +getInstance() : ProcessManager$
        +ensureStarted()
        +restartServer()
        +shutdown()
        +sendMessage(String, String, Map, List) : CompletableFuture~JsonNode~
        +stopMessage(String) : CompletableFuture~Void~
        +sendRequest(String, Object) : CompletableFuture~JsonNode~
    }

    class AcpProtocolClient {
        <<Closeable>>
        -AtomicLong nextId
        -InputStream input
        -PrintWriter output
        -Map~Long,CompletableFuture~ pendingRequests
        -Map~String,Consumer~ notificationListeners
        -Map~String,RequestHandler~ requestHandlers
        +sendRequest(String, Object) : CompletableFuture~JsonNode~
        +sendNotification(String, Object)
        +onNotification(String, Consumer)
        +onRequest(String, RequestHandler)
        +connect()
        +close()
    }

    class SessionStateMachine {
        -SessionState state
        -List~Consumer~ listeners
        +getState() : SessionState
        +transitionTo(SessionState)
        +canSendMessage() : boolean
        +canStopMessage() : boolean
    }

    class ServerProcessLifecycle {
        -Process serverProcess
        -AtomicReference~AcpProtocolClient~ rpcClient
        -ToolExecutor toolExecutor
        +ensureStarted()
        +startServer() : CompletableFuture~Void~
        +stopServer()
        +restartServer()
    }

    class AcpReconnectManager {
        -int restartCount
        -long lastRestartTime
        +handleDisconnection(Runnable)
        +resetThrottle()
    }

    class AcpRequestRouter {
        -ObjectMapper objectMapper
        -PermissionHandler permissionHandler
        +handleReadTextFile(JsonNode) : CompletableFuture~JsonNode~
        +handleRequestPermission(JsonNode) : CompletableFuture~JsonNode~
    }

    class SessionRpcClient {
        -ProcessManager processManager
        +getSessions(String) : CompletableFuture~JsonNode~
        +createSession(String) : CompletableFuture~JsonNode~
        +loadSessionFromServer(String) : CompletableFuture~JsonNode~
        +deleteSession(String) : CompletableFuture~Void~
        +renameSessionOnServer(String, String) : CompletableFuture~Void~
    }

    class SessionCacheManager {
        -List~Session~ cachedSessions
        -Map~String,Session~ sessionCacheMap
        +getCachedSessions() : List~Session~
        +cacheSession(Session)
        +isDescendantOfCurrent(String) : boolean
    }

    class StrategyRegistry {
        <<UpdateDispatcher>>
        -Cache~String,Map~ toolCallCache
        +handle(SessionUpdate, UIHandler)
    }

    class SubAgentTitleResolver {
        <<utility>>
        +resolve(String, String, String, String) : String$
    }

    %% ------------------------------------------------------------------------
    %% MCP Layer — Tool Server
    %% ------------------------------------------------------------------------

    class McpManager {
        +start() : CompletableFuture~Void~
        +stop()
        +waitForReady() : CompletableFuture~Void~
        +disable()
        +isDisabled() : boolean
        +checkServerSupport(JsonNode)
        +getServerConfig() : List~Map~
    }

    class McpToolAdapter {
        <<ToolExecutor>>
        -McpManager mcpManager
        +start()
        +stop()
        +waitForReady() : CompletableFuture~Void~
    }

    class McpServer {
        -int port
        +start() : CompletableFuture~Void~
        +stop()
        +getPort() : int
    }

    class McpTools {
        +registerTool(McpToolDefinition, ToolExecutor)
        +getTools() : List
        +callTool(String, JsonNode) : JsonNode
    }

    %% ------------------------------------------------------------------------
    %% UI Layer — Presentation
    %% ------------------------------------------------------------------------

    class AssistantTopComponent {
        <<TopComponent, PermissionHandler>>
        -ChatThreadPanel chatPanel
        -ConfigPanelController configCtrl
        -SessionLifecycleHandler sessionLifecycleHandler
        -ComponentLifecycleHandler componentLifecycleHandler
        -MessageSender messageSender
        -InputHandler inputHandler
        -StatusController statusController
        +componentOpened()
        +onUserMessage(String)
        +stopGeneration()
    }

    class ChatThreadPanel {
        <<JPanel, Scrollable>>
        -StreamingCoordinator streamingCoord
        -MessageFilterManager filterMgr
        -BubbleFactory bubbleFactory
        -ScrollController scrollCtrl
        +addMessage(MessageType, String, String)
        +stopStreaming()
        +clearMessages()
        +setMessages(List~ProcessedMessage~)
        +applyTypeFilters()
    }

    class MessageBubble {
        <<JPanel, Scrollable>>
        -BubbleStreamer streamer
        -BubbleContentRenderer contentRenderer
        -BubbleAccordionManager accordionMgr
        -BubbleThemeApplier themeApplier
        +appendText(String)
        +flushUpdate()
        +finalizeStreaming(boolean, boolean)
        +setSegmentedToolContent(List~ToolSegment~)
    }

    class PlaceholderTextArea {
        <<JTextArea, Scrollable>>
        -String placeholder
        +setPlaceholder(String)
        +getPlaceholder() : String
    }

    class BaseCollapsiblePane {
        <<abstract RoundedPanel>>
        #JPanel header
        #JLabel headerLabel
        #JPanel contentPanel
        #boolean expanded
        +setExpanded(boolean)
        +toggle()
        +setTitle(String)
        +setContent(String)
        +appendContent(String)
    }

    class CollapsibleActivityPane {
        <<BaseCollapsiblePane>>
        -JTextArea contentArea
        -List~ToolSegment~ segments
        +setContent(String)
        +setSegmentedContent(List~ToolSegment~)
    }

    class CollapsibleToolPane {
        <<BaseCollapsiblePane>>
        -JTextArea textArea
        -List~ToolSegment~ segments
        +setContent(String)
        +setSegmentedContent(List~ToolSegment~)
    }

    class CollapsibleCodePane {
        <<BaseCollapsiblePane>>
        -RSyntaxTextArea codeTextArea
        -String language
        +setCode(String, String)
    }

    class AccordionGroup {
        -List~BaseCollapsiblePane~ panes
        +register(BaseCollapsiblePane)
        +toggleAll()
        +setAllExpanded(boolean)
    }

    class StreamingCoordinator {
        -MessageBubble activeStreamBubble
        -Timer streamFlushTimer
        +startStreaming(MessageBubble)
        +stopStreaming() : MessageBubble
        +cleanup()
    }

    class BubbleStreamer {
        -JTextArea streamingTextArea
        -Timer deferredFinalizeTimer
        +appendText(String)
        +flushUpdate()
        +finalizeStreaming(boolean, boolean)
    }

    class BubbleContentRenderer {
        -JPanel segments
        -StringBuilder text
        +handleToolThoughtContent(ColorTheme, boolean, String)
        +handleAssistantContent(ColorTheme, boolean)
        +buildCodePanes(String, ColorTheme)
    }

    class BubbleAccordionManager {
        -JPanel segments
        +registerWithAccordionGroup(AccordionGroup)
        +toggleAllBlocks(boolean)
    }

    class BubbleThemeApplier {
        -MessageBubble owner
        -JPanel bubblePanel
        +applyBubbleTheme(ColorTheme, String)
        +buildHeaderPanel(String, String, ColorTheme)
    }

    class BubbleFactory {
        <<utility>>
        +createToolThoughtBubble(...) MessageBubble$
        +createRoleBubble(...) MessageBubble$
        +resolveAvatarPosition(...) : AvatarPosition$
    }

    class ToolThoughtCombiner {
        <<utility>>
        +combine(List~ProcessedMessage~) : ProcessedMessage$
    }

    class MarkdownStyledRenderer {
        <<utility>>
        +render(String, ColorTheme) : JTextPane$
    }

    class MarkdownTokenizer {
        <<utility>>
        +nextFormatMarker(String, int) : FormatMatch$
    }

    class StyleResolver {
        <<utility>>
        +baseStyle(Font, Color) : SimpleAttributeSet$
        +headerStyle(...) : SimpleAttributeSet$
        +codeBlockStyle(...) : SimpleAttributeSet$
    }

    class HtmlContentPreparer {
        <<utility>>
        +prepareHtml(String) : String$
    }

    class FitEditorPane {
        <<JTextPane>>
        +createHtmlPane() : FitEditorPane$
        +setText(String)
    }

    class TableDetector {
        <<utility>>
        +detectTables(String) : List~List~String~~$
    }

    class ScrollController {
        <<KeyEventDispatcher>>
        +isAtBottom() : boolean
        +scrollToBottom()
    }

    class MessageFilterManager {
        <<utility>>
        +isTypeHidden(String) : boolean$
        +setTypeHidden(String, boolean)$
        +getEffectiveMessageTypes() : String[]$
    }

    class ThemeManager {
        <<singleton>>
        +getCurrentTheme() : ColorTheme$
        +getFont() : Font$
        +getIcon(String, int) : Icon$
    }

    class ColorTheme {
        <<record>>
        +isDark boolean
        +background() : Color
        +foreground() : Color
        +bubbleUser() : Color
        +bubbleAssistant() : Color
        +sunkenBackground() : Color
    }

    class IconResourceManager {
        <<singleton>>
        +getIcon(String, int) : Icon$
        +getFont() : Font$
    }

    class RoundedPanel {
        <<JPanel>>
        #int radius
        +paintComponent(Graphics)
    }

    class ChatLayoutBuilder {
        +buildHeaderPanel() : JPanel
        +buildBottomPanel() : JPanel
        +getRightStatusPanel() : JPanel
    }

    class SessionLifecycleHandler {
        <<SessionListener>>
        +onSessionListUpdated(List~Session~)
        +onSessionLoaded(String, List, boolean)
        +onSessionUpdate(SessionUpdate)
        +onSessionError(String)
    }

    class ComponentLifecycleHandler {
        +componentOpened()
        +componentActivated()
        +componentClosed()
    }

    class MessageSender {
        +sendUserMessage(String)
        +stopMessage()
    }

    class InputHandler {
        +keyPressed(KeyEvent)
        +install(JTextArea)
    }

    class StatusController {
        +setStatus(String)
        +setThinking(boolean)
        +setEnabled(boolean)
    }

    class ConfigPanelController {
        -ModelVariantResolver modelResolver
        -JComboBox~ConfigItem~ modelCombo
        +updateConfigOptions(List~SessionConfigOption~)
    }

    class ModelVariantResolver {
        -LinkedHashMap modelVariants
        +parseModelVariants(SessionConfigOption)
        +resolveModelId(String, String) : String
        +getStartupDefaults(...) : Map
    }

    class AttachmentManager {
        +addAttachment(AttachedFile)
        +getAttachments() : List~AttachedFile~
        +clear()
    }

    class AttachmentUiHandler {
        +getButton() : JButton
    }

    class PermissionDialogManager {
        +handleRequest(String, JsonNode, CompletableFuture)
    }

    class PermissionBubble {
        <<JPanel>>
        +setText(String)
    }

    class SessionDropdownHandler {
        +sessionSelected(String)
    }

    class WelcomeScreen {
        <<JPanel>>
        +updateSessions(List~Session~)
    }

    class HistorySearchDialog {
        <<JDialog>>
        +showDialog()
    }

    class UIUtils {
        <<utility>>
        +createToolbarButton(String, int, String, ActionListener) : JButton$
        +createRoundedComboBox(...) : JComboBox$
    }

    %% ------------------------------------------------------------------------
    %% Relationships — Contract Implementations
    %% ------------------------------------------------------------------------

    SessionControl --|> SessionQuery : extends

    SessionManager ..|> SessionControl : implements
    SessionManager ..|> SessionQuery : implements

    ProcessManager ..|> ProcessControl : implements

    ToolExecutor <|.. McpToolAdapter : implements

    UpdateDispatcher <|.. StrategyRegistry : implements

    SessionListener <|.. SessionLifecycleHandler : implements

    PermissionHandler <|.. AssistantTopComponent : implements

    SlashCommandInterceptor ..> SlashCommandCallback : uses
    SlashCommandInterceptor ..> SlashCommandHandler : uses

    %% ------------------------------------------------------------------------
    %% Relationships — Manager Compositions
    %% ------------------------------------------------------------------------

    SessionManager o-- SessionStateMachine : manages state
    SessionManager o-- SessionCacheManager : delegates caching
    SessionManager o-- SessionRpcClient : delegates RPC
    SessionManager ..> ProcessControl : Lookup query

    ProcessManager o-- ServerProcessLifecycle : delegates start/stop
    ProcessManager o-- AcpReconnectManager : handles reconnect
    ProcessManager o-- AcpRequestRouter : routes requests
    ProcessManager o-- AcpProtocolClient : owns RPC transport
    ProcessManager o-- McpToolAdapter : delegates tool execution
    ProcessManager o-- SlashCommandInterceptor : intercepts commands

    ServerProcessLifecycle ..> AcpProtocolClient : initializes
    AcpReconnectManager ..> AcpProtocolClient : reconnects
    AcpRequestRouter ..> PermissionHandler : delegates permissions

    SessionRpcClient ..> ProcessManager : calls sendRequest

    StrategyRegistry ..> SubAgentTitleResolver : resolves titles
    StrategyRegistry ..> ToolDataExtractor : extracts tool data

    %% ------------------------------------------------------------------------
    %% Relationships — MCP Compositions
    %% ------------------------------------------------------------------------

    McpManager o-- McpServer : manages server
    McpManager o-- McpTools : manages tools
    McpToolAdapter o-- McpManager : adapts

    %% ------------------------------------------------------------------------
    %% Relationships — UI Compositions
    %% ------------------------------------------------------------------------

    AssistantTopComponent o-- ChatThreadPanel : creates & owns
    AssistantTopComponent o-- ConfigPanelController : creates & owns
    AssistantTopComponent o-- SessionLifecycleHandler : creates & owns
    AssistantTopComponent o-- ComponentLifecycleHandler : creates & owns
    AssistantTopComponent o-- MessageSender : creates & owns
    AssistantTopComponent o-- InputHandler : creates & owns
    AssistantTopComponent o-- StatusController : creates & owns
    AssistantTopComponent o-- AttachmentUiHandler : uses

    ChatThreadPanel o-- StreamingCoordinator : delegates streaming
    ChatThreadPanel ..> BubbleFactory : creates bubbles via
    ChatThreadPanel ..> MessageFilterManager : queries visibility
    ChatThreadPanel ..> ScrollController : auto-scroll control

    MessageBubble o-- BubbleStreamer : delegates streaming append
    MessageBubble o-- BubbleContentRenderer : delegates render update
    MessageBubble o-- BubbleAccordionManager : delegates expand/collapse
    MessageBubble o-- BubbleThemeApplier : delegates theme colors

    BubbleContentRenderer ..> CollapsibleActivityPane : creates
    BubbleContentRenderer ..> CollapsibleCodePane : creates
    BubbleContentRenderer ..> CollapsibleToolPane : creates
    BubbleContentRenderer ..> FitEditorPane : creates
    BubbleContentRenderer ..> HtmlContentPreparer : converts markdown

    BubbleAccordionManager ..> AccordionGroup : registers with

    BubbleThemeApplier ..> MessageBubble : updates owner background

    BaseCollapsiblePane <|-- CollapsibleActivityPane : extends
    BaseCollapsiblePane <|-- CollapsibleCodePane : extends
    BaseCollapsiblePane <|-- CollapsibleToolPane : extends

    AccordionGroup o-- BaseCollapsiblePane : manages panes

    MarkdownStyledRenderer ..> MarkdownTokenizer : tokenizes inline markup
    MarkdownStyledRenderer ..> StyleResolver : resolves token→attributes

    ChatLayoutBuilder ..> AssistantTopComponent : builds layout for
    ChatLayoutBuilder ..> UIUtils : uses utilities

    SessionLifecycleHandler ..> SessionControl : Lookup query
    SessionLifecycleHandler ..> ChatThreadPanel : updates chat
    SessionLifecycleHandler ..> ConfigPanelController : updates config

    ComponentLifecycleHandler ..> ProcessControl : Lookup query
    ComponentLifecycleHandler ..> SessionControl : Lookup query

    MessageSender ..> ProcessControl : Lookup query
    MessageSender ..> SlashCommandInterceptor : intercepts commands

    PermissionDialogManager ..> PermissionHandler : routes requests
    PermissionDialogManager o-- PermissionBubble : displays bubble

    ConfigPanelController o-- ModelVariantResolver : resolves models
    ConfigPanelController ..> SessionControl : Lookup query

    ModelVariantResolver ..> SessionControl : Lookup query

    AttachmentManager o-- AttachmentUiHandler : manages state

    SessionDropdownHandler ..> SessionControl : Lookup query

    %% ------------------------------------------------------------------------
    %% Relationships — Theme & Rendering
    %% ------------------------------------------------------------------------

    ThemeManager ..> ColorTheme : provides
    ThemeManager ..> IconResourceManager : delegates icons/fonts

    BaseCollapsiblePane ..> ThemeManager : reads icons & fonts
    CollapsibleCodePane ..> ThemeManager : reads fonts
    BubbleStreamer ..> ColorTheme : reads
    BubbleContentRenderer ..> ColorTheme : reads
    BubbleThemeApplier ..> ColorTheme : reads
    MarkdownStyledRenderer ..> ColorTheme : reads

    %% ------------------------------------------------------------------------
    %% Relationships — Constants Usage
    %% ------------------------------------------------------------------------

    BubbleStreamer ..> JsonFields : string constants
    AcpProtocolClient ..> JsonFields : string constants
    StrategyRegistry ..> JsonFields : string constants
    ServerProcessLifecycle ..> JsonFields : string constants
    ToolDataExtractor ..> JsonFields : string constants
    ToolContextExtractor ..> JsonFields : string constants

    MessageBubble ..> TimingConstants : stream flush timing
    StreamingCoordinator ..> TimingConstants : stream flush timing

    PreferenceKeys ..> PluginSettings : preference constants
